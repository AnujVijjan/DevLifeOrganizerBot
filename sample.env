# ─────────────────────────────────────────────
# Slack Configuration
# ─────────────────────────────────────────────

# Bot token (starts with xoxb-) — used for posting messages to channels
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# User token (starts with xoxp-) — used for sending direct messages (Deep Work mode)
SLACK_USER_TOKEN=xoxp-your-slack-user-token

# The channel where the bot posts summaries and PR results (e.g. #dev-life)
SLACK_CHANNEL=#your-slack-channel

# Your own Slack user ID (e.g. U012AB3CD) — used to exclude your messages from auto-reply
SLACK_USER_ID=your-slack-user-id

# ─────────────────────────────────────────────
# GitHub Configuration
# ─────────────────────────────────────────────

# Personal access token with repo + read:org scopes
GITHUB_TOKEN=ghp-your-github-token

# Your GitHub username — used to filter commits in standup reports and PR reminders
GITHUB_USERNAME=your-github-username

# GitHub organisation name — all API calls are scoped to this org
GITHUB_ORG=your-github-org

# Comma-separated branch names the bot monitors for PRs and commits
GITHUB_BRANCH_NAMES=master,develop,main

# Comma-separated keywords used to filter which repos the bot watches
# Repos whose names contain any of these keywords will be included
REPO_SEARCH_KEYWORDS=frontend,backend,api

# ─────────────────────────────────────────────
# Jira Configuration
# ─────────────────────────────────────────────

# Base URL of your Jira instance
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Email address associated with your Jira account
JIRA_EMAIL=your-email@example.com

# Jira API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-jira-api-token

# Project key used for JQL queries in standup reports (e.g. PROJ)
JIRA_PROJECT_KEY=YOURPROJECT

# ─────────────────────────────────────────────
# Jira Workflow Configuration
# ─────────────────────────────────────────────
# These control how the bot transitions tickets after a DEV PR is created.
# Default values match a common Jira setup — override only if your workflow differs.

# Status name that triggers the CodeReview transition (default: "In Progress")
JIRA_STATUS_IN_PROGRESS=In Progress

# Name of the transition to move the ticket to after PR creation (default: "CodeReview")
JIRA_STATUS_CODE_REVIEW=CodeReview

# Jira custom field ID that holds the QA tester (default: customfield_10111)
# Find yours at: https://yourcompany.atlassian.net/rest/api/3/field
JIRA_QA_TESTER_FIELD=customfield_10111
